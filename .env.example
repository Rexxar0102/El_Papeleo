# Configuración de Supabase
# Copia este archivo como .env y completa los valores
# O usa --dart-define al ejecutar flutter run

# URL del proyecto Supabase (https://tu-proyecto.supabase.co)
SUPABASE_URL=https://tlfeqazjhawrzfwawwjx.supabase.co

# Anon key pública (Dashboard > Settings > API > anon public)
SUPABASE_ANON_KEY=pega-tu-anon-key-aqui

# Service role key (solo para backend/admin, NO usar en cliente)
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
